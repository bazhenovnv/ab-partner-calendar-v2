# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_in_production

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_in_production

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_min_32_chars_in_production
SESSION_SECRET=change_me_min_32_chars_in_production

# ─── Bots ─────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
MAX_BOT_TOKEN=
# ─── MAX Import ───────────────────────────────────────────────────────────────
# Set to true only after configuring MAX_SOURCE_CHANNEL_ID and MAX_WEBHOOK_SECRET.
MAX_IMPORT_ENABLED=false
# Numeric chat ID of the approved MAX source channel.
# Obtain by adding the bot to the channel and reading the bot_added update log.
MAX_SOURCE_CHANNEL_ID=
# Public-facing channel URL (displayed in events, not used for API calls).
MAX_SOURCE_CHANNEL_URL=https://max.ru/join/LNPW5HIAqvWwUH1vQtB5V1kytLpmG18IsNURG4is4B0
# Secret for validating X-Max-Bot-Api-Secret header. 5–256 chars: A-Z a-z 0-9 hyphen.
MAX_WEBHOOK_SECRET=
# Full public HTTPS URL where MAX will POST webhook events (port 443 required).
MAX_WEBHOOK_PUBLIC_URL=https://ab-event.pro/api/max-webhook
ADMIN_TELEGRAM_CHAT_ID=
# Shared secret for internal bot→backend API calls. Must match value in apps/backend and apps/bots.
BOT_INTERNAL_TOKEN=change_me_min_32_chars_in_production
# Telegram bot username without @. Used for deep-link «Напомнить» button on event pages.
# Without this variable the Telegram reminder button is hidden on the site.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
# MAX bot URL. Used for deep-link «Напомнить в MAX» button on event pages.
NEXT_PUBLIC_MAX_BOT_URL=https://max.ru/id2308283362_bot

# ─── Analytics ────────────────────────────────────────────────────────────────
YANDEX_METRIKA_ID=110270689
# Frontend-exposed Metrika counter ID (must match YANDEX_METRIKA_ID)
NEXT_PUBLIC_YANDEX_METRIKA_ID=110270689

# ─── App ──────────────────────────────────────────────────────────────────────
APP_VERSION=latest
NEXT_PUBLIC_SITE_URL=https://ab-event.pro
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_CONTACT_EMAIL=info-event@a-b.ru

# ─── Seed (first deploy only) ─────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@ab-event.pro
SEED_ADMIN_PASSWORD=change_me_first_login
